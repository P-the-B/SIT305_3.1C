<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".ResultActivity">

    <!-- top row: spacer pushes toggle to the right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- dark mode switch: checked = dark, unchecked = light -->
        <Switch
            android:id="@+id/btnToggleTheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dark Mode"
            android:textSize="12sp"
            android:checked="false"/>

    </LinearLayout>

    <!-- centred results content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvCongrats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Congratulations!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- personalised message set dynamically in ResultActivity.java -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Well done, [Name]"
            android:textSize="18sp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR SCORE:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- score shown as X/Y, set dynamically -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- percentage shown below score, set dynamically -->
        <TextView
            android:id="@+id/tvPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="20sp"
            android:textColor="#757575"
            android:layout_marginBottom="48dp"/>

        <!-- retake quiz, passes name back to MainActivity -->
        <Button
            android:id="@+id/btnTakeNewQuiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Take New Quiz"
            android:layout_marginBottom="16dp"/>

        <!-- closes all activities -->
        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finish"/>

    </LinearLayout>

</LinearLayout>